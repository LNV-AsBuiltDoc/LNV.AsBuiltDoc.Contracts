{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://lnv-asbuiltdoc.github.io/LNV.AsBuiltDoc.Contracts/standards/assembler/assembler.input.schema.v1.json",
  "title": "Assembler Input Contract",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "bundle", "contracts", "template"],
  "properties": {
    "schemaVersion": { "type": "integer", "const": 1 },
    "bundle": {
      "type": "object",
      "additionalProperties": false,
      "required": ["rootPath"],
      "properties": {
        "rootPath": { "type": "string", "minLength": 1 },
        "strict": { "type": "boolean", "default": true }
      }
    },
    "contracts": {
      "type": "object",
      "additionalProperties": false,
      "required": ["rootPath", "version"],
      "properties": {
        "rootPath": { "type": "string", "minLength": 1 },
        "version": { "type": "string", "minLength": 1 }
      }
    },
    "template": {
      "type": "object",
      "additionalProperties": false,
      "required": ["profileId"],
      "properties": {
        "profileId": { "type": "string", "minLength": 1 },
        "path": { "type": "string" }
      }
    },
    "options": {
      "type": "object",
      "additionalProperties": true
    }
  }
}
