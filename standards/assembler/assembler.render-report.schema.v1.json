{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://lnv-asbuiltdoc.github.io/LNV.AsBuiltDoc.Contracts/standards/assembler/assembler.render-report.schema.v1.json",
  "title": "Assembler Render Report",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "status", "startedUtc", "completedUtc", "stages", "issues"],
  "properties": {
    "schemaVersion": { "type": "integer", "const": 1 },
    "status": { "type": "string", "enum": ["OK", "PARTIAL", "ERROR"] },
    "startedUtc": { "type": "string", "format": "date-time" },
    "completedUtc": { "type": "string", "format": "date-time" },
    "bundleId": { "type": ["string", "null"] },
    "stages": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["name", "status", "startedUtc", "completedUtc"],
        "properties": {
          "name": { "type": "string" },
          "status": { "type": "string", "enum": ["OK", "WARN", "ERROR", "SKIPPED"] },
          "startedUtc": { "type": "string", "format": "date-time" },
          "completedUtc": { "type": "string", "format": "date-time" },
          "details": { "type": ["object", "null"], "additionalProperties": true }
        }
      }
    },
    "issues": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["code", "severity", "message"],
        "properties": {
          "code": { "type": "string" },
          "severity": { "type": "string", "enum": ["INFO", "WARN", "ERROR"] },
          "message": { "type": "string" },
          "path": { "type": ["string", "null"] }
        }
      }
    },
    "outputs": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["path"],
        "properties": {
          "path": { "type": "string" },
          "type": { "type": ["string", "null"] }
        }
      }
    }
  }
}
